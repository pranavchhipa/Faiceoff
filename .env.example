# ==============================================================================
# Faiceoff — Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ==============================================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL from Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Anon/public key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service role key — server-side only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# Used for rate limiting, caching, and queues
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Payment gateway for INR transactions
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ── Inngest ──────────────────────────────────────────────────────────────────
# Background job pipeline (generation processing)
# Get these from https://app.inngest.com → your app → Manage → Keys
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# ── Replicate ─────────────────────────────────────────────────────────────────
# AI model hosting for face generation pipeline
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenRouter ────────────────────────────────────────────────────────────────
# LLM routing for prompt generation and content moderation
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Hive Moderation ──────────────────────────────────────────────────────────
# Content safety and NSFW detection
HIVE_API_KEY=your-hive-api-key

# ── Cloudflare R2 ────────────────────────────────────────────────────────────
# Object storage for generated images and creator assets
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=faiceoff-assets

# ── Resend ────────────────────────────────────────────────────────────────────
# Transactional email delivery (OTPs for both creators and brands)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Faiceoff <noreply@yourdomain.com>

# ── Novu ──────────────────────────────────────────────────────────────────────
# Multi-channel notification infrastructure
NOVU_API_KEY=your-novu-api-key

# ── Sentry ────────────────────────────────────────────────────────────────────
# Error tracking and performance monitoring
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ── PostHog ───────────────────────────────────────────────────────────────────
# Product analytics and feature flags
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Application ──────────────────────────────────────────────────────────────
# The public URL of the application (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
